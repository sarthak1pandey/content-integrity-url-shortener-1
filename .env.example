# ─────────────────────────────────────────
#  LinkGuard — Environment Configuration
# ─────────────────────────────────────────

# Port the server listens on (default: 3000)
PORT=3000

# Your deployment URL (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.railway.app
BASE_URL=http://localhost:3000

# Optional: Your name as inventor (shown in API health)
INVENTOR_NAME=Sarthak Pandey, VIT Vellore

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key
