{
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://content-integrity-url-shortener-1.onrender.com/api/$1"
    },

    { "src": "^/css/(.*)", "dest": "/css/$1" },
    { "src": "^/js/(.*)", "dest": "/js/$1" },

    { "src": "^/dashboard$", "dest": "/dashboard.html" },
    { "src": "^/link/(.*)", "dest": "/link.html" },
    { "src": "^/s/(.*)", "dest": "/redirect.html" },

    { "src": ".*", "dest": "/index.html" }
  ]
}
